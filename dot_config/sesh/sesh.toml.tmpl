blacklist = ["scratch"]

[default_session]
# startup_command = "nvim +GoToFile"
preview_command = "eza --all --git --icons --color=always {}"

[[session]]
name = "tmux config"
path = "~/.config/tmux"
startup_command = "nvim tmux.conf"

# preview_command = "bat --color=always ~/.config/tmux/tmux.conf"


[[session]]
name = "dotfiles config"
# Source: ~/.local/share/chezmoi (chezmoi source dir, ~/dotfiles no longer exists)
path = "~/.local/share/chezmoi"
# startup_command = "nvim ."


[[session]]
name = "nvim config"
path = "~/.config/nvim"
disable_startup_command = true
windows = ["editor"]


[[session]]
name = "ghostty config"
path = "~/.config/ghostty"
startup_command = "nvim config"
# disable_startup_command = true
# windows = ["editor"]


{{if eq .chezmoi.os "darwin" -}}
[[session]]
name = "petthriftier api"
path = "~/Coding/BackendProjects/pet-thriftier-api"
startup_command = "tmux rename-window cli && tmux split-window -h -c \"#{pane_current_path}\" \"gh dash\" && tmux select-pane -L"
windows = ["editor"]

[[session]]
name = "strata"
path = "~/Coding/IdeaProjects/strata"
startup_command = "tmux rename-window cli && tmux split-window -h -c \"#{pane_current_path}\" \"gh dash\" && tmux select-pane -L"
windows = ["editor"]

[[session]]
name = "second brain"
path = "~/obsidian/Second Brain"
disable_startup_command = true
windows = ["claude"]

[[session]]
name = "creative outlet"
path = "~/obsidian/creative_outlet"
disable_startup_command = true
windows = ["claude"]

[[session]]
name = "pet thriftier frontend"
path = "~/Coding/FrontendProjects/pet-thriftier-frontend"
startup_command = "tmux rename-window cli && tmux split-window -h -c \"#{pane_current_path}\" \"gh dash\" && tmux select-pane -L"
windows = ["editor"]

[[session]]
name = "eline3d nfc"
path = "~/Coding/BackendProjects/eline3d-nfc"
startup_command = "tmux rename-window cli && tmux split-window -h -c \"#{pane_current_path}\" \"gh dash\" && tmux select-pane -L"
windows = ["editor"]

[[session]]
name = "start2save api"
path = "~/Coding/BackendProjects/start2save-api"
startup_command = "tmux rename-window cli && tmux split-window -h -c \"#{pane_current_path}\" \"gh dash\" && tmux select-pane -L"
windows = ["editor"]

[[session]]
name = "nvidia"
path = "~"
startup_command = "ssh song"

[[session]]
name = "ssh juser"
path = "~"
startup_command = "ssh juser"

{{ end -}}





[[session]]
name = "empty"
path = "$HOME"
windows = ["scratch"]
