#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
set -e

# Install Homebrew if not already present
if ! command -v brew &>/dev/null && [ ! -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Make brew available in this session
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

# Install packages via brew (newer versions, consistent with macOS)
brew install zsh tmux fzf ripgrep fd starship atuin yazi sesh eza llvm gh

# System essentials via apt
sudo apt update
sudo apt install -y git curl build-essential unzip

# Add brew zsh to /etc/shells and set as default
BREW_ZSH="$(brew --prefix)/bin/zsh"
if ! grep -q "$BREW_ZSH" /etc/shells 2>/dev/null; then
    echo "$BREW_ZSH" | sudo tee -a /etc/shells
fi
sudo chsh -s "$BREW_ZSH" "$USER"

echo "Bootstrap complete. Open a new shell (zsh) to continue."
{{ end -}}
