[[window]]
name = "editor"
# startup_script = "~/.config/sesh/scripts/editor-root-picker.sh"
startup_script = "nvim ."



[[window]]
name = "cli_gh-dash"
startup_script = "~/.config/sesh/scripts/cli-gh-dash.sh"


[[window]]
name = "claude"
disable_startup_command = true
startup_script = "claude"
