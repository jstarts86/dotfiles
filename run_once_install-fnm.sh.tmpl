#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
set -e

# Install fnm (Fast Node Manager) if not already present
if ! command -v fnm &>/dev/null && [ ! -f "$HOME/.local/share/fnm/fnm" ]; then
    echo "Installing fnm..."
    curl -fsSL https://fnm.vercel.app/install | bash
fi

# Ensure fnm is available in this session
export FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
    export PATH="$FNM_PATH:$PATH"
    eval "$(fnm env --shell zsh)"
fi

# Install Node 22 LTS and set as default
fnm install 22
fnm default 22

echo "Node $(node --version) installed via fnm."
{{ end -}}
